# =============================================================================
# cv-site — environment variables
# =============================================================================
# Copy this file to `.env` and fill in the values for your local setup.
#   cp .env.example .env
# Never commit the .env file to version control.
#
# This project is an iOS-style portfolio frontend. The only env var it actually
# consumes is the candidate's name, which the page title and the CV "Notes"
# widget both read.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Your name as it should appear in the page <title>, meta description, and the
# CV "Notes" widget. Falls back to "Your Name" if unset.
NEXT_PUBLIC_CV_NAME=Your Name
